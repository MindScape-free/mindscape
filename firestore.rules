rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'ldTOigUhGqX5x8UAOj1ouTZIyfm1';
    }

    /* =========================
       USER PRIVATE DATA
    ========================== */
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // allows admin count() queries
      allow write: if isOwner(userId);

      match /settings/{settingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      // Chat Sessions — Firestore-persisted (replaces localStorage)
      match /chatSessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /mindmaps/{mindmapId} {
        allow create: if isOwner(userId)
          && request.resource.data.userId == userId;
        allow read: if isOwner(userId) || isAdmin() || resource.data.isPublic == true;
        allow update: if isOwner(userId)
          && (!('userId' in resource.data) || resource.data.userId == userId);
        allow delete: if isOwner(userId);

        match /nodes/{nodeId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }

        match /content/{docId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId);
        }
      }
    }

    /* =========================
       PUBLIC MIND MAPS
    ========================== */
    match /publicMindmaps/{mindmapId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.originalAuthorId == request.auth.uid;

      allow update: if isSignedIn() && (
        (resource.data.originalAuthorId == request.auth.uid)
        ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']))
      );

      allow delete: if isSignedIn() && (
        resource.data.originalAuthorId == request.auth.uid
        || isAdmin()
      );
    }

    /* =========================
       SHARED MIND MAPS (UNLISTED)
    ========================== */
    match /sharedMindmaps/{mindmapId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.originalAuthorId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.originalAuthorId == request.auth.uid;

      allow delete: if isSignedIn() && (
        resource.data.originalAuthorId == request.auth.uid
        || isAdmin()
      );
    }

    /* =========================
       ADMIN STATS
       — read and written by admin client directly (no Cloud Functions needed)
    ========================== */
    match /adminStats/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // admin syncs stats directly from the dashboard
    }

    /* =========================
       CHAT SESSIONS (collectionGroup for admin count)
    ========================== */
    match /{path=**}/chatSessions/{sessionId} {
      allow read: if isAdmin(); // allows admin collectionGroup count() queries
    }
  }
}
